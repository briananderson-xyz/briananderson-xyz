{
  "name": "briananderson-xyz",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "generate-variants": "node scripts/generate-variants.js",
    "build-content-index": "tsx scripts/build-content-index.ts",
    "prebuild": "npm run generate-variants && npm run build-content-index",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:ui": "node scripts/validate-ui.js",
    "test:posthog": "node scripts/validate-posthog.js",
    "test:resumes": "tsx scripts/validate-resumes.ts",
    "test:ai": "node scripts/validate-ai.js",
    "test:ai:evals:smoke": "AI_EVAL_ONLY_DESCRIPTIONS=\"AWS experience answer stays grounded in Brian's background,Prompt extraction attempt is refused without leaking internal instructions,Projects query returns concrete project names (search_projects),Strong platform role shows evidence-backed fit,Unrelated clinical role is scored as not fit with gaps\" node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml ai-evals/fit-finder.promptfoo.yaml",
    "test:ai:evals": "node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml ai-evals/fit-finder.promptfoo.yaml",
    "test:ai:evals:chat": "node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml",
    "test:ai:evals:fit-finder": "node scripts/run-ai-evals.js ai-evals/fit-finder.promptfoo.yaml",
    "test:ai:evals:local": "AI_EVAL_BASE_URL=http://127.0.0.1:5173/api AI_EVAL_REPORT_PATH=artifacts/ai-evals-local.json node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml ai-evals/fit-finder.promptfoo.yaml",
    "test:ai:evals:local:chat": "AI_EVAL_BASE_URL=http://127.0.0.1:5173/api AI_EVAL_REPORT_PATH=artifacts/ai-evals-local-chat.json node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml",
    "test:ai:evals:local:fit-finder": "AI_EVAL_BASE_URL=http://127.0.0.1:5173/api AI_EVAL_REPORT_PATH=artifacts/ai-evals-local-fit-finder.json node scripts/run-ai-evals.js ai-evals/fit-finder.promptfoo.yaml",
    "test:ai:loop:local": "bash scripts/run-local-ai-evals.sh",
    "test:ai:evals:prod": "AI_EVAL_BASE_URL=https://api.briananderson.xyz AI_EVAL_REPORT_PATH=artifacts/ai-evals-prod.json node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml ai-evals/fit-finder.promptfoo.yaml",
    "test:ai:evals:prod:chat": "AI_EVAL_BASE_URL=https://api.briananderson.xyz AI_EVAL_REPORT_PATH=artifacts/ai-evals-prod-chat.json node scripts/run-ai-evals.js ai-evals/chat.promptfoo.yaml",
    "test:ai:evals:prod:fit-finder": "AI_EVAL_BASE_URL=https://api.briananderson.xyz AI_EVAL_REPORT_PATH=artifacts/ai-evals-prod-fit-finder.json node scripts/run-ai-evals.js ai-evals/fit-finder.promptfoo.yaml",
    "test:content-index": "tsx scripts/validate-content-index.ts",
    "test:content": "tsx scripts/validate-content.ts && vitest run src/lib/schemas/content.test.ts src/lib/schemas/resume.test.ts",
    "test:workflow-policy": "node scripts/validate-workflow-policy.mjs",
    "test:delivery-policy": "node scripts/validate-delivery-workflows.mjs",
    "test:infra-policy": "bash ../infra/terraform/test-check-policy.sh",
    "test:security-policy": "node scripts/validate-security-policy.mjs",
    "test:theme": "node scripts/validate-theme-tokens.mjs",
    "test:api": "node scripts/validate-api-endpoints.js",
    "test:unit": "vitest run",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:chat": "pnpm exec playwright test chat.spec.ts",
    "test:e2e:fit-finder": "pnpm exec playwright test fit-finder.spec.ts",
    "validate": "pnpm run test:workflow-policy && pnpm run test:delivery-policy && pnpm run test:infra-policy && pnpm run check && pnpm run test:resumes && pnpm run test:content && pnpm run build-content-index && pnpm run test:content-index && pnpm run build && pnpm run test:security-policy && pnpm run test:theme && pnpm run test:ui && pnpm run test:posthog"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.1",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "js-yaml": "^4.3.0",
    "mdsvex": "^0.12.7",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-preprocess": "^5.1.4",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-svelte": "^0.462.0",
    "marked": "^17.0.6",
    "posthog-js": "^1.399.1",
    "web-vitals": "^4.2.4",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "cookie@0.6.0": "0.7.2",
      "js-yaml@3.14.1": "3.15.0",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@9.0.5": "9.0.7",
      "brace-expansion@1.1.12": "1.1.13",
      "flatted@3.3.3": "3.4.2",
      "glob@10.4.5": "10.5.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "rollup@4.46.2": "4.59.0",
      "yaml@2.8.1": "2.8.3"
    }
  }
}
